  },
  "dependencies": {
    "cac": "6.7.14"
  },
  "devDependencies": {
    "@types/node": "24.12.2",
    "esbuild": "0.27.7",
    "tsx": "4.21.0",
    "typescript": "6.0.3",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": "~24"
  }
}
