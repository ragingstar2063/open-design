{
  "name": "@open-design/tools-serve",
  "version": "0.6.0",
  "private": true,
  "type": "module",
  "bin": {
    "tools-serve": "./bin/tools-serve.mjs"
  },
  "scripts": {
    "build": "node ./esbuild.config.mjs && tsc -p tsconfig.json --emitDeclarationOnly",
    "dev": "tsx ./src/index.ts",
